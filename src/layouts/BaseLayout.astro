---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Sofía Jaquete — Product & Service Designer' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>
  <div class="intro-overlay" id="intro-overlay">
    <canvas id="intro-canvas"></canvas>
  </div>

  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursor-ring"></div>

  <nav class="nav">
    <a href="/" class="nav-logo">SJ<span class="nav-logo-dot">.</span></a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/#work" class="nav-work">Work</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/resume">Resume</a></li>
      <li><a href="mailto:sofiavjaquete@gmail.com" class="nav-cta">Let's talk →</a></li>
    </ul>
    <button class="nav-burger" id="nav-burger" aria-label="Menu">
      <span></span><span></span>
    </button>
  </nav>

  <div class="mobile-menu" id="mobile-menu">
    <ul>
      <li><a href="/">Home</a></li>
      <li><a href="/#work" class="nav-work">Work</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/resume">Resume</a></li>
      <li><a href="mailto:sofiavjaquete@gmail.com">Let's talk</a></li>
    </ul>
  </div>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <p class="footer-name">Sofía Jaquete</p>
      <p class="footer-copy">© {new Date().getFullYear()} — Product & Service Designer</p>
      <div class="footer-links">
        <a href="https://linkedin.com/in/sofiavjaquete" target="_blank" rel="noopener">LinkedIn ↗</a>
        <a href="mailto:sofiavjaquete@gmail.com">Email ↗</a>
      </div>
    </div>
  </footer>
</body>
</html>

<script>
  // Intro anemone loader
  (function() {
    const overlay = document.getElementById('intro-overlay');
    const canvas = document.getElementById('intro-canvas') as HTMLCanvasElement;
    if (!overlay || !canvas) return;

    if (sessionStorage.getItem('intro-seen')) {
      overlay.style.display = 'none';
      return;
    }
    sessionStorage.setItem('intro-seen', '1');

    const DPR = Math.min(devicePixelRatio, 2);
    const SIZE = 320 * DPR;
    canvas.width = SIZE;
    canvas.height = SIZE;
    const ctx = canvas.getContext('2d')!;
    const cx = SIZE * 0.5, cy = SIZE * 0.62;

    function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }

    const rings = [
      { n: 5,  phiRange:[0.05,0.18], lenMul:0.50 },
      { n: 9,  phiRange:[0.18,0.35], lenMul:0.75 },
      { n: 13, phiRange:[0.35,0.52], lenMul:0.95 },
      { n: 14, phiRange:[0.52,0.68], lenMul:1.08 },
      { n: 11, phiRange:[0.68,0.85], lenMul:1.05 },
      { n: 8,  phiRange:[1.00,1.12], lenMul:1.00 },
      { n: 6,  phiRange:[1.12,1.25], lenMul:0.85 },
      { n: 4,  phiRange:[1.25,1.38], lenMul:0.65 },
    ];

    const BASE_LEN = SIZE * 0.28;
    const PITCH = 0.32;
    const CP = Math.cos(PITCH), SP = Math.sin(PITCH);

    interface Stream { theta: number; phi: number; len: number; speed: number; phase: number; freq: number; curl: number; progress: number; }
    const streams: Stream[] = [];

    rings.forEach(ring => {
      for (let i = 0; i < ring.n; i++) {
        const theta = (i / ring.n) * Math.PI * 2 + (Math.random() - 0.5) * 0.5;
        const phi = lerp(ring.phiRange[0], ring.phiRange[1], Math.random()) * (Math.PI / 2);
        streams.push({
          theta, phi,
          len: BASE_LEN * ring.lenMul * (0.70 + Math.random() * 0.90),
          speed: 0.008 + Math.random() * 0.006,
          phase: Math.random() * Math.PI * 2,
          freq: 0.6 + Math.random() * 0.6,
          curl: (Math.random() - 0.5) * 0.25,
          progress: 0,
        });
      }
    });

    function project(x: number, y: number, z: number) {
      const yc = y * CP + z * SP;
      const zc = -y * SP + z * CP;
      const fov = SIZE * 3.5;
      const s = fov / (fov + zc);
      return { sx: cx + x * s, sy: cy - yc * s };
    }

    let tick = 0;
    let rotAngle = 0;
    let allDone = false;

    function drawStream(s: Stream) {
      const SEGS = 12;
      const sway1 = Math.sin(tick * s.freq + s.phase) * s.len * 0.26;
      const sway2 = Math.sin(tick * s.freq * 0.65 + s.phase + 1.2) * s.len * 0.14;
      const curl = s.curl * s.len * (0.8 + Math.sin(tick * 0.18 + s.phase) * 0.4);
      const swayY = Math.sin(tick * s.freq * 0.75 + s.phase + 0.8) * s.len * 0.20;

      const sinPhi = Math.sin(s.phi), cosPhi = Math.cos(s.phi);
      const th = s.theta + rotAngle;
      const ox = sinPhi * Math.cos(th), oy = cosPhi, oz = sinPhi * Math.sin(th);
      const px = -Math.sin(th), pz = Math.cos(th);
      const rx = Math.cos(th) * cosPhi, rz = Math.sin(th) * cosPhi;

      if (s.progress > 0 && s.progress < 1) s.progress = Math.min(1, s.progress + 0.015);

      const totalSegs = Math.floor(SEGS * s.progress);
      if (totalSegs < 1) return;

      ctx.beginPath();
      ctx.strokeStyle = `rgba(20, 230, 210, ${0.4 + s.progress * 0.5})`;
      ctx.lineWidth = 1.5;
      ctx.lineCap = 'round';

      for (let i = 0; i <= totalSegs; i++) {
        const f = i / SEGS;
        const env = f * Math.sin(f * Math.PI * 1.1);
        const sw1 = sway1 * env, sw2 = sway2 * env, syv = swayY * env, cu = curl * f * f;
        const dist = SIZE * 0.02 + s.len * f;
        const p = project(ox * dist + px * (sw1 + cu) + rx * sw2, oy * dist + syv, oz * dist + pz * (sw1 + cu) * 0.3 + rz * sw2 * 0.3);
        if (i === 0) ctx.moveTo(p.sx, p.sy);
        else ctx.lineTo(p.sx, p.sy);
      }
      ctx.stroke();
    }

    function animate() {
      ctx.clearRect(0, 0, SIZE, SIZE);
      streams.forEach(s => drawStream(s));
      tick += 0.007;
      rotAngle += 0.0004;
      allDone = streams.every(s => s.progress >= 1);
      if (!allDone) {
        requestAnimationFrame(animate);
      } else {
        setTimeout(() => {
          overlay.classList.add('fade-out');
          setTimeout(() => overlay.remove(), 900);
        }, 300);
      }
    }

    // Stagger stream start
    streams.forEach((s, i) => {
      setTimeout(() => { s.progress = 0.001; }, i * 18);
    });

    animate();
  })();

  // Custom cursor
  const cursor = document.getElementById('cursor')!;
  const ring = document.getElementById('cursor-ring')!;
  let mx = 0, my = 0, rx = 0, ry = 0;

  document.addEventListener('mousemove', e => {
    mx = e.clientX; my = e.clientY;
    cursor.style.transform = `translate(${mx - 30}px, ${my - 30}px)`;
  });

  function animateRing() {
    rx += (mx - rx - 18) * 0.12;
    ry += (my - ry - 18) * 0.12;
    ring.style.transform = `translate(${rx}px, ${ry}px)`;
    requestAnimationFrame(animateRing);
  }
  animateRing();

  document.querySelectorAll('a, button').forEach(el => {
    el.addEventListener('mouseenter', () => { cursor.classList.add('hover'); ring.classList.add('hover'); });
    el.addEventListener('mouseleave', () => { cursor.classList.remove('hover'); ring.classList.remove('hover'); });
  });

  document.querySelector('.nav-work')?.addEventListener('click', (e) => {
    const work = document.getElementById('work');
    if (work) {
      e.preventDefault();
      work.scrollIntoView({ behavior: 'smooth' });
    }
  });

  document.querySelectorAll('img, video, .card-images, .feature-images').forEach(el => {
    el.addEventListener('mouseenter', () => cursor.classList.add('on-image'));
    el.addEventListener('mouseleave', () => cursor.classList.remove('on-image'));
  });

  // Burger menu
  const burger = document.getElementById('nav-burger')!;
  const menu = document.getElementById('mobile-menu')!;
  burger.addEventListener('click', () => {
    menu.classList.toggle('open');
    burger.classList.toggle('open');
  });

  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));
</script>

<style>
  /* Intro overlay */
  .intro-overlay {
    position: fixed;
    inset: 0;
    background: var(--bg);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.75s cubic-bezier(.76,0,.24,1);
  }
  .intro-overlay.fade-out { opacity: 0; transition: opacity 0.8s ease; }
  #intro-canvas {
    width: 320px;
    height: 320px;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2.5rem;
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(8,8,8,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    font-family: var(--serif);
    font-size: 1.3rem;
    letter-spacing: -0.01em;
    color: var(--text);
    transition: opacity 0.2s;
  }
  .nav-logo-dot { color: var(--accent); }
  .nav-logo:hover { opacity: 0.7; }

  .nav-links {
    display: flex;
    list-style: none;
    align-items: center;
    gap: 2.5rem;
  }

  .nav-links a {
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); }

  .nav-cta {
    color: var(--text) !important;
    border: 1px solid var(--border-light);
    padding: 0.45rem 1rem;
    border-radius: 999px;
    font-size: 0.82rem !important;
    transition: border-color 0.2s, background 0.2s !important;
  }
  .nav-cta:hover { border-color: var(--accent) !important; background: rgba(124,106,247,0.08) !important; }

  .nav-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: 4px;
  }
  .nav-burger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--text);
    transition: transform 0.25s, opacity 0.25s;
  }
  .nav-burger.open span:first-child { transform: translateY(6.5px) rotate(45deg); }
  .nav-burger.open span:last-child { transform: translateY(-6.5px) rotate(-45deg); }

  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--bg);
    z-index: 99;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .mobile-menu.open { opacity: 1; pointer-events: all; }
  .mobile-menu ul { list-style: none; text-align: center; }
  .mobile-menu li { margin-bottom: 2rem; }
  .mobile-menu a { font-family: var(--serif); font-size: 2.5rem; color: var(--text); transition: color 0.2s; }
  .mobile-menu a:hover { color: var(--accent); }

  main { padding-top: 52px; }

  .footer {
    border-top: 1px solid var(--border);
    padding: 3rem 2.5rem;
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-name {
    font-family: var(--serif);
    font-size: 1.1rem;
  }
  .footer-copy { font-size: 0.8rem; color: var(--text-muted); }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a { font-size: 0.82rem; color: var(--text-muted); transition: color 0.2s; }
  .footer-links a:hover { color: var(--text); }

  @media (max-width: 680px) {
    .nav { padding: 1.25rem 1.5rem; }
    .nav-links { display: none; }
    .nav-burger { display: flex; }
    .mobile-menu { display: flex; }
    main { padding-top: 64px; }
  }
</style>
