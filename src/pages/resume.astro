---
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = [
  {
    role: 'Product Designer',
    company: 'Thoropass — B2B Auditing Software',
    period: 'Aug 2024 – Dec 2025',
    description: 'Designed features for a B2B compliance and auditing platform, working closely with engineering and product to ship AI-powered tools that reduce manual auditor workload.',
  },
  {
    role: 'Product & Service Designer',
    company: 'Azulo — SaaS FinTech',
    period: 'Jan 2020 – Apr 2024',
    description: 'Led end-to-end design of a digital health loan product connecting Costa Ricans with healthcare centers and banks. Grew the customer base by 20% and built a design system that boosted team efficiency by 50%.',
  },
  {
    role: 'Freelance Product & UX Researcher',
    company: 'Independent',
    period: 'Mar 2021 – Apr 2024',
    description: 'Owned design for an AI compliance platform (50% cycle time reduction), conducted user research and usability testing, mapped service blueprints, facilitated cross-functional workshops, and designed a water monitoring platform for industrial users.',
  },
];

const competencies = [
  'Product Strategy', 'Service Design', 'UX Research', 'Prototyping',
  'Design Systems', 'Stakeholder Management', 'Workshop Facilitation',
];

const tools = ['Figma', 'Framer', 'Miro', 'Illustrator', 'Photoshop', 'Claude'];
---
<BaseLayout title="Resume — Sofía Jaquete" description="Professional experience and background of Sofía Jaquete.">
  <div class="page">
    <div class="page-header">
      <div>
        <h1>Resume</h1>
        <p class="subtitle">Product & Service Designer</p>
      </div>
      <a href="/cv.pdf" download class="download-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download CV
      </a>
    </div>

    <section class="section">
      <h2>Experience</h2>
      <div class="entries">
        {experience.map(e => (
          <div class="entry">
            <div class="entry-meta">
              <span class="entry-period">{e.period}</span>
            </div>
            <div class="entry-body">
              <h3>{e.role}</h3>
              <p class="entry-company">{e.company}</p>
              <p class="entry-desc">{e.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <h2>Core competencies</h2>
      <div class="tags">
        {competencies.map(c => <span class="tag">{c}</span>)}
      </div>
    </section>

    <section class="section">
      <h2>Tools</h2>
      <div class="tags">
        {tools.map(t => <span class="tag">{t}</span>)}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page { max-width: 800px; margin: 0 auto; padding: 4rem 2rem 6rem; }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4rem;
    gap: 1rem;
  }

  h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.4rem; }
  .subtitle { color: var(--text-muted); }

  .download-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    border: 1px solid var(--accent);
    color: var(--accent);
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.2s, color 0.2s, transform 0.15s;
  }
  .download-btn:hover { background: var(--accent); color: #fff; transform: translateY(-1px); }

  .section { margin-bottom: 3.5rem; }

  h2 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    font-weight: 500;
    margin-bottom: 2rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .entries { display: flex; flex-direction: column; gap: 2.5rem; }

  .entry { display: grid; grid-template-columns: 140px 1fr; gap: 2rem; }

  .entry-period { font-size: 0.8rem; color: var(--text-muted); white-space: nowrap; padding-top: 0.15rem; }

  h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.25rem; }
  .entry-company { font-size: 0.9rem; color: var(--accent); margin-bottom: 0.6rem; }
  .entry-desc { font-size: 0.9rem; color: var(--text-muted); line-height: 1.7; }

  .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag {
    font-size: 0.85rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .page { padding: 2.5rem 1.25rem 4rem; }
    .entry { grid-template-columns: 1fr; gap: 0.4rem; }
    .page-header { flex-direction: column; }
  }
</style>
