---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Projects — Sofía Jaquete" description="Case studies and design work by Sofía Jaquete.">
  <div class="page">
    <div class="page-header">
      <h1>Projects</h1>
      <p class="subtitle">{projects.length} case studies — brand, product, and UX</p>
    </div>
    <div class="grid">
      {projects.map(p => (
        <ProjectCard
          title={p.data.title}
          summary={p.data.summary}
          role={p.data.role}
          tools={p.data.tools}
          slug={p.id}
          coverImage={p.data.coverImage}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 600px) {
    .page { padding: 2.5rem 1.25rem; }
  }
</style>
