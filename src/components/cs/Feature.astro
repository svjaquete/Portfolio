---
interface Props {
  heading: string;
  images: string[];
  noRotate?: boolean;
  stacked?: boolean;
}
const { heading, images, noRotate = false, stacked = false } = Astro.props;
---
<div class={`feature${noRotate ? ' feature--straight' : ''}${stacked ? ' feature--stacked' : ''}`}>
  <div class="feature-inner reveal">
    <div class="feature-text">
      <h2>{heading}</h2>
      <div class="feature-body"><slot /></div>
    </div>
    <div class="feature-images">
      {images.map((src, i) => (
        <div class={`img-wrap img-${i}`}>
          <img src={src} alt={`${heading} — image ${i + 1}`} loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</div>
<style>
  .feature {
    padding: 8rem 2.5rem 5rem;
    border-bottom: 1px solid var(--border);
    overflow: visible;
  }
  .feature-inner {
    max-width: 1100px;
    margin: 0 auto;
    overflow: visible;
    display: grid;
    align-items: start;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  h2 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }
  .feature-body {
    font-size: 0.97rem;
    color: var(--text-muted);
    line-height: 1.8;
  }
  .feature-body :global(p) { margin-bottom: 1rem; }
  .feature-images {
    position: relative;
    width: 100%;
    height: 900px;
    overflow: visible;
    perspective: 1000px;
  }
  .img-wrap {
    position: absolute;
    overflow: visible;
  }
  .img-wrap img {
    display: block;
    width: 100%;
    height: auto;
  }
  .feature-images .img-0 {
    width: 568px;
    top: -90px;
    left: -60px;
    z-index: 4;
    border-radius: 28px;
    overflow: hidden;
    transform: rotate(4deg);
  }
  .feature-images .img-1 {
    display: none;
  }
  .feature-images .img-2 {
    width: 422px;
    top: 145px;
    left: 80px;
    z-index: 2;
    transform: rotate(10deg);
  }
  .feature-images .img-3 {
    width: 422px;
    top: 293px;
    left: 125px;
    z-index: 1;
    transform: rotate(16deg);
  }

  .img-wrap {
    opacity: 0;
    transform: translateY(-700px) scale(0.8) !important;
    transition: opacity 1s cubic-bezier(0.22, 1, 0.36, 1), transform 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .img-wrap.img-0.visible {
    opacity: 1;
    transform: rotate(4deg) rotateY(-20deg) rotateX(15deg) !important;
  }
  .img-wrap.img-2.visible {
    opacity: 1;
    transform: rotate(4deg) rotateY(-20deg) rotateX(15deg) !important;
  }
  .img-wrap.img-3.visible {
    opacity: 1;
    transform: rotate(4deg) rotateY(-25deg) rotateX(10deg) !important;
  }
  .img-wrap.img-0 { transition-delay: 100ms; }
  .img-wrap.img-2 { transition-delay: 450ms; }
  .img-wrap.img-3 { transition-delay: 800ms; }

  .feature--stacked .feature-inner {
    grid-template-columns: 1fr;
  }
  .feature--stacked .feature-text {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }
  .feature--stacked .feature-images {
    height: auto;
    position: relative;
    display: flex;
    flex-direction: row;
    gap: 1.5rem;
  }
  .feature--stacked .img-wrap {
    position: relative !important;
    width: auto !important;
    top: auto !important;
    left: auto !important;
    right: auto !important;
    flex: 1;
  }
  .feature--stacked .img-wrap img {
    width: 100%;
    border-radius: 10px;
  }
  .feature--stacked .img-wrap.img-0 {
    width: 100% !important;
    top: auto !important;
    left: auto !important;
    transform: none !important;
    border-radius: 10px;
    overflow: visible;
  }
  .feature--stacked .img-wrap.img-1 {
    display: block !important;
    width: 100% !important;
    top: auto !important;
    left: auto !important;
    transform: none !important;
  }

  .feature--straight .img-wrap,
  .feature--straight .img-wrap.img-0.visible,
  .feature--straight .img-wrap.img-2.visible,
  .feature--straight .img-wrap.img-3.visible {
    transform: none !important;
  }

  @media (max-width: 768px) {
    .feature-inner { grid-template-columns: 1fr; }
    .feature { padding: 3rem 1.5rem; }
    .feature-images { height: 360px; min-height: unset; }
    .feature-images .img-0 { width: 85%; top: -20px; left: 0; }
    .feature-images .img-2 { width: 70%; top: 120px; left: 20px; }
    .feature-images .img-3 { width: 65%; top: 200px; left: 30px; }
  }
</style>

<script>
  const container = document.querySelector('.feature-images');
  const cards = container.querySelectorAll('.img-wrap');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        cards.forEach(card => card.classList.add('visible'));
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2, rootMargin: '0px 0px -300px 0px' });
  observer.observe(container);
</script>
