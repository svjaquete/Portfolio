---
interface Props { label: string }
const { label } = Astro.props;
---
<div class="desc-row reveal">
  <div class="desc-label">{label}</div>
  <div class="desc-content"><slot /></div>
</div>
<style>
  .desc-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
    padding: 1.2rem 0;
    max-width: 1100px;
    margin: 0 auto;
    background: var(--bg);
  }

  .desc-label {
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 700;
    color: var(--text);
    padding-top: 0.1rem;
  }

  .desc-content {
    font-size: 0.97rem;
    color: var(--text-muted);
    line-height: 1.75;
  }

  .desc-content :global(strong) { color: var(--text); font-weight: 600; }
  .desc-content :global(p) { margin-bottom: 0.75rem; }
  .desc-content :global(p:last-child) { margin-bottom: 0; }

  @media (max-width: 680px) {
    .desc-row { grid-template-columns: 1fr; gap: 0.75rem; padding: 2rem 0; }
  }
</style>
