---
interface Props {
  images: string[];
  cols?: number;
  alt?: string;
  caption?: string;
  light?: boolean;
}
const { images, cols = 1, alt = '', caption, light = false } = Astro.props;
---
<div class={`img-grid-wrap reveal${light ? ' light' : ''}`}>
  {caption && <p class="img-caption">{caption}</p>}
  <div class={`img-grid cols-${cols}`}>
    {images.map((src, i) => (
      <div class="img-item">
        <img src={src} alt={alt || `Image ${i + 1}`} loading="lazy" />
      </div>
    ))}
  </div>
</div>
<style>
  .img-grid-wrap {
    padding: 2rem 2.5rem;
    background: var(--bg);
  }
  .img-grid-wrap.light .img-item {
    background: #e8e8e8;
    padding: 1.5rem;
    border-radius: 8px;
  }

  .img-caption {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    padding: 0.75rem 2.5rem;
    margin: 0;
  }

  .img-grid {
    display: grid;
    gap: 0;
    background: var(--bg);
    max-width: 900px;
    margin: 0 auto;
  }

  .cols-1 { grid-template-columns: 1fr; }
  .cols-2 {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 1rem;
  }
  .cols-2 .img-item {
    flex: none;
  }
  .cols-2 .img-item img {
    width: auto !important;
    height: 260px !important;
    object-fit: unset;
  }
  .cols-3 { grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .cols-4 { grid-template-columns: repeat(4, 1fr); }

  .img-item {
    background: var(--bg);
    overflow: hidden;
    display: flex;
    align-items: stretch;
  }
  .img-item img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center top;
    display: block;
    transition: transform 0.5s cubic-bezier(.16,1,.3,1);
  }
  .img-item:hover img { transform: scale(1.02); }

  @media (max-width: 680px) {
    .cols-3, .cols-4 { grid-template-columns: repeat(2, 1fr); }
  }
</style>
