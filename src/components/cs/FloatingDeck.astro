---
interface Props {
  laptop: string;
  screens: string[];
  caption?: string;
}
const { laptop, screens, caption } = Astro.props;
---
<div class="deck-wrap">
  <div class="deck-text">
    <ul>
      <li>Update information throughout the loan lifecycle.</li>
      <li>A profile detailing an overview of the customer, the loan status, associated documents, and all actions taken within the case.</li>
      <li>Calculate the payments of the loan, how much goes to the medical center and how much goes to the doctor, even if there is a surplus.</li>
    </ul>
  </div>
  <div class="deck">
    <img class="deck-item deck-laptop" src={laptop} alt="Platform overview" loading="lazy" />
    {screens.map((src, i) => (
      <img class={`deck-item deck-screen deck-screen-${i}`} src={src} alt={`Screen ${i + 1}`} loading="lazy" />
    ))}
  </div>
</div>

<style>
  .deck-wrap {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2.5rem 6rem;
    box-sizing: border-box;
    overflow: visible;
  }
  .deck-text {
    max-width: 700px;
    margin: 0 auto 6rem;
    text-align: center;
  }
  .deck-text ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .deck-text li {
    font-size: 0.97rem;
    color: var(--text-muted);
    line-height: 1.7;
  }
  .deck {
    position: relative;
    height: 680px;
    width: 100%;
    overflow: visible;
  }

  .deck-item {
    position: absolute;
    object-fit: contain;
    box-shadow: none;
    opacity: 0;
    transform: translateY(-700px) scale(0.8);
    transition: opacity 1s cubic-bezier(0.22, 1, 0.36, 1), transform 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .deck-item.visible {
    opacity: 1;
  }

  /* Front laptop */
  .deck-laptop {
    width: 75%;
    height: auto;
    top: 33%;
    left: 8%;
    z-index: 4;
    border-radius: 10px;
    transition-delay: 0ms;
  }
  .deck-laptop.visible { transform: translateY(0) scale(1); }

  /* Screen 0 — behind-center-left */
  .deck-screen-0 {
    width: 42%;
    top: 0;
    left: 18%;
    z-index: 3;
    transition-delay: 200ms;
  }
  .deck-screen-0.visible { transform: translateY(0) scale(1); }

  /* Screen 1 — behind-center-right (Frame+142) */
  .deck-screen-1 {
    width: 46%;
    top: -12%;
    right: 8%;
    z-index: 2;
    transition-delay: 400ms;
  }
  .deck-screen-1.visible { transform: translateY(0) scale(1); }

  /* Screen 2 — far behind-right (Frame+140) */
  .deck-screen-2 {
    width: 43%;
    top: 28%;
    right: 4%;
    z-index: 1;
    transition-delay: 600ms;
  }
  .deck-screen-2.visible { transform: translateY(0) scale(1); }

  .deck-caption {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    text-align: center;
    margin-top: 2rem;
    grid-column: 1 / -1;
  }

  @media (max-width: 680px) {
    .deck-wrap { padding: 1rem 1.5rem 3rem; }
    .deck { height: auto; display: flex; flex-direction: column; gap: 1rem; }
    .deck-item {
      position: relative !important;
      width: 100% !important;
      top: auto !important; left: auto !important; right: auto !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .deck-text { margin-bottom: 2rem; }
  }
</style>

<script>
  const deck = document.querySelector('.deck');
  const items = deck.querySelectorAll('.deck-item');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        items.forEach(item => item.classList.add('visible'));
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -100px 0px' });
  observer.observe(deck);
</script>
