---
interface Props {
  title: string;
  summary: string;
  role: string;
  tools: string[];
  slug: string;
  coverImage?: string;
  cardImages?: string[];
  index?: number;
  featured?: boolean;
}
const { title, summary, role, tools, slug, coverImage, cardImages, index = 0, featured = false } = Astro.props;
const imgs = cardImages?.length ? cardImages : coverImage ? [coverImage] : [];
---
<a href={`/projects/${slug}`} class={`card reveal${featured ? ' card--featured' : ''}`} data-slug={slug} style={`transition-delay: ${index * 80}ms`}>
  <div class="card-body">
    <span class="card-role">{role}</span>
    <h2 class="card-title">{title}</h2>
    <p class="card-summary">{summary}</p>
    <div class="card-tools">
      {tools.slice(0, 4).map(t => <span class="tag">{t}</span>)}
    </div>
    <span class="card-arrow">View project ↗</span>
  </div>
  <div class="card-images" data-count={imgs.length}>
    {imgs.map((src, i) => (
      <img src={src} alt={`${title} screen ${i+1}`} loading="lazy" class={`img-${i}`} />
    ))}
    {imgs.length === 0 && <div class="card-placeholder" />}
  </div>
</a>

<style>
  .card {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    align-items: center;
    gap: 3rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 4rem;
    transition: border-color 0.3s;
  }
  .card:hover { border-color: var(--border-light); }
  .card:hover .card-arrow { color: var(--accent); }
  .card--featured:hover .card-images[data-count="1"] img {
    filter: drop-shadow(0 20px 40px rgba(255,255,255,0.25));
  }

  [data-slug="azulo-admi"] .card-images[data-count="1"] img {
    transform: scale(1.15) !important;
  }
  [data-slug="azulo-admi"]:hover .card-images[data-count="1"] img {
    transform: scale(1.2) !important;
    filter: drop-shadow(0 20px 40px rgba(255,255,255,0.25));
  }
  .card:not(.card--featured):hover .card-images[data-count="1"] img {
    filter: drop-shadow(0 20px 60px rgba(255,255,255,0.25));
    transition: filter 0.4s ease;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card-role {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    font-weight: 500;
  }

  .card-title {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--text);
  }

  .card-summary {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .card-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-size: 0.7rem;
    border: 1px solid var(--border-light);
    padding: 0.18rem 0.55rem;
    border-radius: 2px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .card-arrow {
    font-size: 0.82rem;
    color: var(--text-muted);
    transition: color 0.25s;
    margin-top: 0.5rem;
  }

  /* Image composition */
  .card-images {
    position: relative;
    height: 600px;
  }

  .card-images img {
    position: absolute;
    border-radius: 16px;
    object-fit: cover;
    box-shadow: none;
    transition: transform 0.5s cubic-bezier(.16,1,.3,1);
  }
  .card-images[data-count="1"] img {
    object-fit: contain !important;
    object-position: center !important;
    transform: scale(1.25);
  }

  .card--featured .card-images {
    height: 600px;
    overflow: visible;
  }
  .card--featured {
    overflow: visible;
  }

  /* 1 image — featured card only */
  .card--featured .card-images[data-count="1"] img {
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    object-fit: contain;
    object-position: center;
    transform: rotate(-38deg) scale(1.3);
    filter: drop-shadow(0 20px 40px rgba(140,80,220,0));
    transition: filter 0.4s ease, transform 0.5s cubic-bezier(.16,1,.3,1);
  }

  /* 1 image */
  .card-images[data-count="1"] img {
    width: 82%;
    height: 95%;
    top: 2%;
    left: 9%;
    object-fit: contain;
    object-position: center;
  }

  /* 2 images */
  .card-images[data-count="2"] .img-0 {
    width: 68%;
    height: 90%;
    top: 5%;
    left: 0;
    transform: rotate(-4deg);
    z-index: 1;
  }
  .card-images[data-count="2"] .img-1 {
    width: 68%;
    height: 90%;
    top: 5%;
    right: 0;
    transform: rotate(4deg);
    z-index: 2;
  }

  /* 3 images */
  .card-images[data-count="3"] .img-0 {
    width: 55%;
    height: 85%;
    top: 8%;
    left: 0;
    transform: rotate(-8deg) translateY(10px);
    z-index: 1;
    object-position: top;
  }
  .card-images[data-count="3"] .img-1 {
    width: 60%;
    height: 90%;
    top: 4%;
    left: 20%;
    transform: rotate(-2deg);
    z-index: 3;
    object-position: top;
  }
  .card-images[data-count="3"] .img-2 {
    width: 55%;
    height: 85%;
    top: 6%;
    right: 0;
    transform: rotate(7deg) translateY(8px);
    z-index: 2;
    object-position: top;
  }

  .card:hover .card-images[data-count="3"] .img-0 { transform: rotate(-10deg) translateY(16px) translateX(-8px); }
  .card:hover .card-images[data-count="3"] .img-2 { transform: rotate(10deg) translateY(14px) translateX(8px); }
  .card:hover .card-images[data-count="2"] .img-0 { transform: rotate(-6deg) translateX(-6px); }
  .card:hover .card-images[data-count="2"] .img-1 { transform: rotate(6deg) translateX(6px); }

  /* 4 images — reference layout: big phone front-left, 3 screens stacked behind-right */
  .card-images[data-count="4"] .img-0 {
    width: 64%;
    height: 96%;
    top: 2%;
    left: 2%;
    transform: rotate(0deg);
    z-index: 4;
    object-position: top;
  }
  .card-images[data-count="4"] .img-1 {
    width: 48%;
    height: 80%;
    top: 2%;
    right: 2%;
    transform: rotate(4deg);
    z-index: 3;
    object-position: top;
  }
  .card-images[data-count="4"] .img-2 {
    width: 44%;
    height: 75%;
    top: 10%;
    right: 10%;
    transform: rotate(10deg);
    z-index: 2;
    object-position: top;
  }
  .card-images[data-count="4"] .img-3 {
    width: 40%;
    height: 70%;
    top: 16%;
    right: 18%;
    transform: rotate(16deg);
    z-index: 1;
    object-position: top;
  }
  .card:hover .card-images[data-count="4"] .img-0 { transform: rotate(-8deg) translateX(-6px); }
  .card:hover .card-images[data-count="4"] .img-1 { transform: rotate(6deg) translateX(6px); }
  .card:hover .card-images[data-count="4"] .img-2 { transform: rotate(13deg) translateX(10px); }
  .card:hover .card-images[data-count="4"] .img-3 { transform: rotate(19deg) translateX(14px); }

  .card-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 16px;
    background: linear-gradient(135deg, #111 0%, #1a1a2e 100%);
  }

  @media (max-width: 768px) {
    .card {
      grid-template-columns: 1fr;
      padding: 2rem 1.5rem;
      gap: 1.5rem;
    }
    .card-images { height: 260px; }
    .card--featured .card-images { height: 260px; }
    .card-title { font-size: clamp(1.5rem, 6vw, 2rem); }
  }
</style>
